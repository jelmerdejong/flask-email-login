# Core application settings
SECRET_KEY=change-me

# Optional: override the default SQLite database
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/flask_email_login

# Mail delivery settings
MAIL_SERVER=localhost
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# Set to true to suppress SMTP delivery and read the login link from the app logs.
MAIL_SUPPRESS_SEND=false
